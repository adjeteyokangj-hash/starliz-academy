{
  "name": "starliz-academy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "npm run test:curriculum-coverage && npm run audit:ai-curriculum",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "tsx --test tests/csv_escape.test.ts tests/production_flows.test.ts tests/tenant_isolation.test.ts tests/governance_flows.test.ts tests/curriculum_coverage.test.ts",
    "test:curriculum-coverage": "tsx --test tests/curriculum_coverage.test.ts",
    "audit:ai-curriculum": "tsx scripts/audit_ai_curriculum.ts",
    "test:e2e:assigned-loop": "playwright test tests/e2e/assigned-content-loop.spec.ts",
    "test:e2e:retry-pack": "playwright test tests/e2e/retry-pack-completion.spec.ts",
    "test:e2e:schools-ops": "playwright test --workers=1 tests/e2e/admin-schools-ops.spec.ts tests/e2e/admin-schools-ops-cleanup.spec.ts",
    "test:e2e:schools-ops-cleanup": "playwright test tests/e2e/admin-schools-ops-cleanup.spec.ts",
    "seed:admin": "node scripts/seed_admin.mjs",
    "migration:export": "tsx scripts/migration_export.ts",
    "migration:import": "tsx scripts/migration_import.ts",
    "migration:sync:prod": "tsx scripts/migrate_local_to_production.ts",
    "seed:ops-scenarios": "prisma db execute --file ./scripts/seed_ops_scenarios.sql",
    "cleanup:ops-scenarios": "prisma db execute --file ./scripts/cleanup_ops_scenarios.sql",
    "smoke:routes": "node scripts/smoke_routes.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^3.0.3",
    "imapflow": "^1.3.3",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "prisma": "^6.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
